# Local development example
# Copy this file to .env and fill in real values.

# MongoDB Atlas (recommended)
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTERHOST/es_gamma_analyzer?retryWrites=true&w=majority

# Optional
MONGODB_DB=es_gamma_analyzer
MONGODB_PRESSURE_COLLECTION=pressure_points

# Optional: where to store login/logout events
MONGODB_LOGIN_COLLECTION=login_sessions

# Optional: where to store the last analyzed PDF per user
MONGODB_LAST_ANALYSIS_COLLECTION=last_analysis

# Optional: TTL for login session logs (days). Default: 90
LOGIN_SESSIONS_TTL_DAYS=90

# Optional: change Flask port (default in app.py is 5005)
# PORT=5005

# Google OAuth (required for web dashboard login)
# Create an OAuth Client (Web application) in Google Cloud Console.
# Authorized redirect URI (local): http://localhost:5005/auth/callback
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Flask session secret (required) — generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=replace-with-a-32-byte-random-hex-string

# Optional: restrict admin pages to these emails (comma-separated)
# If empty, any authenticated user can access /admin locally.
# On Vercel (VERCEL=1), the allowlist is REQUIRED.
ADMIN_EMAILS=luca.taurisano@bitsharp.it

# Financial Modeling Prep API key (primary source for screener fundamentals;
# yfinance is fallback when missing or on FMP errors). Get a key at
# https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=
